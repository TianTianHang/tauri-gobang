From: Tauri Gobang Project <tauri-gobang@example.com>
Date: Fri, 28 Mar 2026 21:03:00 +0000
Subject: [PATCH 1/2] Fix pthread linking on Android

Android NDK does not support explicit -lpthread linking, as pthread
functionality is built into libc. This change adds an Android check
to skip pthread linking on Android platforms.

This fixes the build error:
  "cannot find -lpthread" when building for Android.
---
 Rapfi/CMakeLists.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/Rapfi/CMakeLists.txt b/Rapfi/CMakeLists.txt
index 2eac180..c3ef6e1 100644
--- a/Rapfi/CMakeLists.txt
+++ b/Rapfi/CMakeLists.txt
@@ -546,7 +546,7 @@ elseif(CMAKE_CXX_COMPILER_ID STREQUAL "GNU" OR CMAKE_CXX_COMPILER_ID STREQUAL "C
         if(NO_COMMAND_MODULES)
             target_link_libraries(rapfi PRIVATE -static)
         endif()
-    elseif(NOT EMSCRIPTEN)
+    elseif(NOT EMSCRIPTEN AND NOT ANDROID)
         if(NO_MULTI_THREADING AND NO_COMMAND_MODULES)
             target_link_libraries(rapfi PRIVATE -static)
         elseif(CMAKE_SYSTEM_NAME STREQUAL "Darwin" AND CMAKE_CXX_COMPILER_ID MATCHES "Clang|AppleClang")
--
2.34.1
